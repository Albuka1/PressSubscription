<Window x:Class="PressSubscription.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:views="clr-namespace:PressSubscription.Views"
        Title="PressSubscription - Учёт подписки на печатные издания"
        Height="700"
        Width="1200"
        MinHeight="550"
        MinWidth="900"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgColor}"
        WindowState="Maximized">

    <Window.Resources>
        <!-- Стиль для заголовка вкладки -->
        <Style x:Key="TabHeaderStyle" TargetType="TabItem">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0,0,0,3"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter x:Name="ContentPresenter"
                                              ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderBrush" Value="{StaticResource PrimaryColor}"/>
                                <Setter Property="Foreground" Value="{StaticResource PrimaryColor}"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#E8F5E9"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <DockPanel>

        <!-- Верхняя панель -->
        <Border DockPanel.Dock="Top" 
                Background="White" 
                BorderBrush="{StaticResource BorderColor}" 
                BorderThickness="0,0,0,1"
                Height="50">

            <DockPanel>
                
                <!-- Логотип и название -->
                <StackPanel Orientation="Horizontal" Margin="20,0">
                    <Image Source="Assets/logo.png" Width="32" Height="32" Margin="0,0,10,0"/>
                    <TextBlock Text="PressSubscription" 
                               FontSize="18" 
                               FontWeight="Bold" 
                               VerticalAlignment="Center"/>
                </StackPanel>
                
                <StackPanel Orientation="Horizontal" 
                            HorizontalAlignment="Center" 
                            VerticalAlignment="Center">
                    <Button x:Name="ImportButton" 
                            Content="Импорт из Excel" 
                            Click="Import_Click"
                            Style="{StaticResource PrimaryButton}"
                            Padding="12,6"
                            Visibility="Collapsed"/>
                </StackPanel>

                <!-- Правая часть с пользователем -->
                <StackPanel Orientation="Horizontal" 
                            HorizontalAlignment="Right" 
                            VerticalAlignment="Center"
                            Margin="0,0,20,0">
                    
                    <Border Background="#F0F0F0" 
                            CornerRadius="20" 
                            Padding="10,5"
                            Margin="0,0,15,0">
                        <TextBlock x:Name="UserInfoText" 
                                   FontSize="12" 
                                   VerticalAlignment="Center"/>
                    </Border>
                    
                    <Button x:Name="LogoutButton" 
                            Content="🚪 Выйти" 
                            Click="Logout_Click"
                            Style="{StaticResource DangerButton}"
                            Padding="12,6"/>
                </StackPanel>

            </DockPanel>
        </Border>

        <!-- Табы -->
        <TabControl x:Name="MainTabControl" 
                    TabStripPlacement="Top"
                    BorderThickness="0"
                    Background="White"
                    Margin="0,0,0,0">

            <!-- Вкладка: Подписчики -->
            <TabItem Header="📋 Подписчики" Style="{StaticResource TabHeaderStyle}">
                <Border Background="{StaticResource BgColor}" Padding="15">
                    <views:SubscribersControl x:Name="SubscribersControl"/>
                </Border>
            </TabItem>

            <!-- Вкладка: Издания -->
            <TabItem Header="📰 Издания" Style="{StaticResource TabHeaderStyle}">
                <Border Background="{StaticResource BgColor}" Padding="15">
                    <views:PublicationsControl x:Name="PublicationsControl"/>
                </Border>
            </TabItem>

            <!-- Вкладка: Подписки -->
            <TabItem Header="📌 Подписки" Style="{StaticResource TabHeaderStyle}">
                <Border Background="{StaticResource BgColor}" Padding="15">
                    <views:SubscriptionsControl x:Name="SubscriptionsControl"/>
                </Border>
            </TabItem>

            <!-- Вкладка: Админ панель (видна только админу) -->
            <TabItem x:Name="AdminTabItem" 
                     Header="⚙️ Админ панель" 
                     Style="{StaticResource TabHeaderStyle}"
                     Visibility="Collapsed">
                <Border Background="{StaticResource BgColor}" Padding="15">
                    <views:AdminPanelControl x:Name="AdminPanelControl"/>
                </Border>
            </TabItem>

        </TabControl>

    </DockPanel>
</Window>