<UserControl x:Class="PressSubscription.Views.SubscribersControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource TopPanelBorder}" Margin="0,0,0,15">
            <StackPanel>
                <WrapPanel Margin="0,0,0,10">
                    <Button x:Name="AddButton" Content="➕ Добавить" Click="Add_Click" Margin="5" Padding="12,8"/>
                    <Button x:Name="EditButton" Content="✏️ Редактировать" Click="Edit_Click" Margin="5" Padding="12,8"/>
                    <Button x:Name="DeleteButton" Content="🗑️ Удалить" Click="Delete_Click" Margin="5" Padding="12,8"/>
                    <Button x:Name="ExportButton" Content="📎 Экспорт" Click="Export_Click" Margin="5" Padding="12,8" Visibility="Collapsed"/>
                </WrapPanel>

                <WrapPanel>
                    <TextBlock Text="🔍 Поиск:" VerticalAlignment="Center" Margin="5,0"/>
                    <TextBox x:Name="SearchBox" Width="300" Margin="5" TextChanged="SearchBox_TextChanged"/>
                    <Button Content="🔄 Сбросить" Click="Reset_Click" Margin="15,5,5,5" Padding="12,8"/>
                </WrapPanel>
            </StackPanel>
        </Border>

        <DataGrid x:Name="SubscribersGrid" 
                  Grid.Row="1"
                  AutoGenerateColumns="True"
                  CanUserAddRows="False"
                  SelectionMode="Single"
                  IsReadOnly="True"
                  RowHeight="40"
                  AlternatingRowBackground="#F9F9F9"/>

    </Grid>
</UserControl>