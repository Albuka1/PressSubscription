<Window x:Class="PressSubscription.Views.SubscribersWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Подписчики"
        Height="500"
        Width="800">

    <DockPanel>

        <Border DockPanel.Dock="Top"
                Background="White"
                Padding="10"
                BorderBrush="#E0E0E0"
                BorderThickness="0,0,0,1">

            <StackPanel>
                
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <Button Content="Добавить" Click="Add_Click" Margin="5"/>
                    <Button Content="Редактировать" Click="Edit_Click" Margin="5"/>
                    <Button Content="Удалить" Click="Delete_Click" Margin="5"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Поиск:" VerticalAlignment="Center" Margin="5,0"/>
                    <TextBox x:Name="SearchBox" Width="250" Margin="5" TextChanged="SearchBox_TextChanged"/>
                    <Button Content="Сбросить" Click="Reset_Click" Margin="15,5,5,5"/>
                </StackPanel>
                
            </StackPanel>

        </Border>

        <DataGrid x:Name="SubscribersGrid"
                  Margin="10"
                  AutoGenerateColumns="True"
                  Background="White"
                  BorderBrush="#E0E0E0"
                  CanUserAddRows="False"
                  SelectionMode="Single"/>

    </DockPanel>

</Window>