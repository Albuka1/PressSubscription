<Window x:Class="PressSubscription.Views.SubscriptionsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Подписки"
        Height="550"
        Width="1000"
        MinHeight="400"
        MinWidth="800"
        WindowStartupLocation="CenterScreen">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- TOP PANEL -->
        <Border Grid.Row="0"
                Background="White"
                Padding="10"
                BorderBrush="#E0E0E0"
                BorderThickness="0,0,0,1">

            <StackPanel>
                
                <!-- Buttons row -->
                <WrapPanel Margin="0,0,0,10">
                    <Button Content="Добавить" Click="Add_Click" Margin="5" Padding="10,5"/>
                    <Button Content="Редактировать" Click="Edit_Click" Margin="5" Padding="10,5"/>
                    <Button Content="Удалить" Click="Delete_Click" Margin="5" Padding="10,5"/>
                </WrapPanel>

                <!-- Search row -->
                <WrapPanel>
                    <TextBlock Text="Поиск:" VerticalAlignment="Center" Margin="5,0"/>
                    <TextBox x:Name="SearchBox" Width="200" Margin="5" TextChanged="SearchBox_TextChanged"/>
                    <Button Content="Сбросить" Click="Reset_Click" Margin="5" Padding="10,5"/>
                </WrapPanel>
                
            </StackPanel>

        </Border>

        <!-- SCROLLABLE GRID -->
        <ScrollViewer Grid.Row="1" 
                      VerticalScrollBarVisibility="Auto"
                      HorizontalScrollBarVisibility="Auto"
                      Margin="10">
            
            <DataGrid x:Name="SubscriptionsGrid"
                      AutoGenerateColumns="False"
                      Background="White"
                      BorderBrush="#E0E0E0"
                      CanUserAddRows="False"
                      SelectionMode="Single"
                      MinWidth="900">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                    <DataGridTextColumn Header="Подписчик" Binding="{Binding Subscriber.FullName}" Width="150"/>
                    <DataGridTextColumn Header="Издание" Binding="{Binding Publication.Title}" Width="150"/>
                    
                    <DataGridTextColumn Header="Старт" Width="100">
                        <DataGridTextColumn.Binding>
                            <Binding Path="StartDate" StringFormat="dd.MM.yyyy"/>
                        </DataGridTextColumn.Binding>
                    </DataGridTextColumn>
                    
                    <DataGridTextColumn Header="Месяцев" Binding="{Binding Months}" Width="80"/>
                    
                    <DataGridTextColumn Header="База" Width="100">
                        <DataGridTextColumn.Binding>
                            <Binding Path="BaseCost" StringFormat="{}{0:N2} ₽"/>
                        </DataGridTextColumn.Binding>
                    </DataGridTextColumn>
                    
                    <DataGridTextColumn Header="Доставка (1%)" Width="110">
                        <DataGridTextColumn.Binding>
                            <Binding Path="DeliveryCost" StringFormat="{}{0:N2} ₽"/>
                        </DataGridTextColumn.Binding>
                    </DataGridTextColumn>
                    
                    <DataGridTextColumn Header="НДС (18%)" Width="100">
                        <DataGridTextColumn.Binding>
                            <Binding Path="Vat" StringFormat="{}{0:N2} ₽"/>
                        </DataGridTextColumn.Binding>
                    </DataGridTextColumn>
                    
                    <DataGridTextColumn Header="Итого" Width="100">
                        <DataGridTextColumn.Binding>
                            <Binding Path="TotalCost" StringFormat="{}{0:N2} ₽"/>
                        </DataGridTextColumn.Binding>
                    </DataGridTextColumn>
                    
                </DataGrid.Columns>

            </DataGrid>
            
        </ScrollViewer>
        
    </Grid>
</Window>