<UserControl x:Class="PressSubscription.Views.AdminPanelControl"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:local="clr-namespace:PressSubscription.Views">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource TopPanelBorder}" Margin="0,0,0,15">
            <StackPanel>
                <TextBlock Text="⚙️ Управление пользователями" 
                           FontSize="18" 
                           FontWeight="Bold" 
                           Margin="0,0,0,10"/>
                
                <WrapPanel>
                    <Button Content="👑 Назначить администратором" 
                            Style="{StaticResource WarningButton}"
                            Click="MakeAdmin_Click" 
                            Margin="5" 
                            Padding="12,8"/>
                    
                    <Button Content="⬇️ Снять права администратора" 
                            Style="{StaticResource DangerButton}"
                            Click="RemoveAdmin_Click" 
                            Margin="5" 
                            Padding="12,8"/>
                    
                    <Button Content="🔒 Заблокировать" 
                            Click="BlockUser_Click" 
                            Margin="5" 
                            Padding="12,8"/>
                    
                    <Button Content="🔓 Разблокировать" 
                            Click="UnblockUser_Click" 
                            Margin="5" 
                            Padding="12,8"/>
                    
                    <Button Content="🔄 Обновить" 
                            Click="Refresh_Click" 
                            Margin="5" 
                            Padding="12,8"/>
                </WrapPanel>
                
                <TextBlock Text="⚠️ Внимание: Нельзя изменять права самого себя!" 
                           Foreground="#FF9800" 
                           FontSize="11" 
                           Margin="5,10,0,0"/>
                
                <TextBlock x:Name="AdminCountText" 
                           FontSize="11" 
                           Opacity="0.6" 
                           Margin="5,5,0,0"/>
            </StackPanel>
        </Border>

        <DataGrid x:Name="UsersGrid" 
                  Grid.Row="1"
                  AutoGenerateColumns="False"
                  CanUserAddRows="False"
                  SelectionMode="Single"
                  IsReadOnly="True"
                  RowHeight="40"
                  AlternatingRowBackground="#F9F9F9">

            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Логин" Binding="{Binding Username}" Width="120"/>
                <DataGridTextColumn Header="ФИО" Binding="{Binding FullName}" Width="150"/>
                <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="150"/>
                
                <DataGridTextColumn Header="Роль" Width="130">
                    <DataGridTextColumn.Binding>
                        <Binding Path="Role">
                            <Binding.Converter>
                                <local:RoleToTextConverter/>
                            </Binding.Converter>
                        </Binding>
                    </DataGridTextColumn.Binding>
                </DataGridTextColumn>
                
                <DataGridTextColumn Header="Статус" Width="100">
                    <DataGridTextColumn.Binding>
                        <Binding Path="IsActive">
                            <Binding.Converter>
                                <local:ActiveToTextConverter/>
                            </Binding.Converter>
                        </Binding>
                    </DataGridTextColumn.Binding>
                </DataGridTextColumn>
                
                <DataGridTextColumn Header="Дата регистрации" 
                                    Binding="{Binding CreatedAt, StringFormat='dd.MM.yyyy HH:mm'}" 
                                    Width="130"/>
                
                <DataGridTextColumn Header="Последний вход" 
                                    Binding="{Binding LastLoginAt, StringFormat='dd.MM.yyyy HH:mm'}" 
                                    Width="130"/>
            </DataGrid.Columns>

        </DataGrid>
    </Grid>
</UserControl>